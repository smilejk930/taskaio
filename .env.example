# ==========================================
# [개발 환경 설정] .env.local
# 이 파일은 절대 git에 커밋하지 마세요!
# ==========================================

# 1. Database Type 설정을 위한 작성란 (필수)
# 허용 값: supabase | postgres | sqlite

# DB_TYPE=supabase
# 권장 방식: Connection Pooler 사용 (포트 6543, pgbouncer 태그 포함)
# Supabase 대시보드 (Project Settings > Database > Connection String > URI 탭)에서 복사
# 연결 안정성을 위해 6543 포트를 사용하는 Pooler 방식을 권장
# Project Overview > 상단 중앙 `Connect`커넥터 아이콘 클릭 > Direct > Transaction pooler > Connection string 확인
# DATABASE_URL="postgresql://postgres.[프로젝트-REF-ID]:[DB-비밀번호]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# 기본 연결 방식 (포트 5432)
# DATABASE_URL="postgresql://postgres:[DB-비밀번호]@db.[프로젝트-REF-ID].supabase.co:5432/postgres"

DB_TYPE=postgres
# 형식: postgresql://[사용자명]:[비밀번호]@[아이피/도메인]:[포트]/[데이터베이스명]
DATABASE_URL=

# DB_TYPE=sqlite
# 방식 1: 프로젝트 루트 경로에 sqlite.db 파일로 생성
# DATABASE_URL="sqlite.db"
# 방식 2: 특정 폴더의 절대 경로 지정
# DATABASE_URL="/Users/user/db/local_taskaio.db"

# 3. Supabase Client 연동 정보
# Project Overview > 상단 중앙 `Connect`커넥터 아이콘 클릭 > Framework > Add files 확인
NEXT_PUBLIC_SUPABASE_URL=
# Supabase 대시보드 > Project Settings > API Keys > Legacy anon, service_role API keys 에서 확인
# anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용 (클라이언트 코드에서 절대 사용 금지)
# service_role
SUPABASE_SERVICE_ROLE_KEY=

# 4. NextAuth (로그인 세션 관리)
NEXTAUTH_URL=http://localhost:3000
#git bash에서 `openssl rand -base64 32`
NEXTAUTH_SECRET=